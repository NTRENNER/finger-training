# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# production
/build
# Sandbox-session artifacts: the FUSE-mounted dev environment can't always
# delete these reliably, so we generated build_old_* / _trash_* / build.bak.*
# folders during automated rebuilds. Ignored so they don't pollute git.
build_old_*
_trash_*
build.bak.*
# Dotted variants from later rebuild sessions (build.gone_NNN,
# build.old.TIMESTAMP, build.stale.TIMESTAMP). 57 of these were
# committed before the patterns were added — removed from the tree in
# a separate commit; ignored here so they never come back.
build.gone_*
build.old.*
build.stale.*

# Local backup / session-scratch source files. *.deleted / *.deleted.*
# capture an older soft-delete convention some sessions used in place
# of rm; safer to gitignore than to risk re-committing them.
*.bak
*.bak_*
*.orig
*.deleted
*.deleted.*
src/*.bak
src/*.bak_*
*.patch
!docs/*.patch
src-backup-*.zip

# misc
.DS_Store
.env
.env.*
!.env.example

npm-debug.log*
yarn-debug.log*
yarn-error.log*
.vercel
