# Copy to .env and fill in values from your Supabase dashboard
# (Project Settings → API → URL + anon public key).
#
# Both values are designed to be public — Supabase's anon key is
# the publishable browser key, gated by Row-Level Security policies
# on each table. They will end up in the production JS bundle via
# REACT_APP_* substitution at build time, so don't put any service-
# role / secret keys here.
REACT_APP_SUPABASE_URL=https://your-project-ref.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key-here
